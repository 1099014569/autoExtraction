{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AutoExtraction",
  "version": "0.1.0",
  "identifier": "com.autoextraction.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AutoExtraction",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": [
      "resources/win-api/"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
